generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  displayName      String?
  bio              String?
  avatar           String?
  role             Role      @default(USER)
  isActive         Boolean   @default(true)
  experienceLevel  String?
  dailyWordCount   Int?
  availability     String?
  writingGoals     String[]
  genres           Genre[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  expoPushToken    String?

  posts            Post[]
  comments         Comment[]
  likes            Like[]
  refreshTokens    RefreshToken[]
  matchesInitiated Match[] @relation("MatchesInitiated")
  matchesReceived  Match[] @relation("MatchesReceived")
  notifications    Notification[]
  ideas            Idea[]
  ideaReplies      IdeaReply[]

  prompts          Prompt[]
  promptUpvotes    PromptUpvote[]
  promptSubmissions PromptSubmission[]
  submissionComments SubmissionComment[]

  feedbackRequests FeedbackRequest[]
  feedbackResponses FeedbackResponse[]
  writingLogs      WritingLog[]
  eventParticipations EventParticipant[]

  @@index([email])
  @@index([displayName])
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum Genre {
  FANTASY
  SCI_FI
  ROMANCE
  MYSTERY
  THRILLER
  HORROR
  LITERARY_FICTION
  HISTORICAL_FICTION
  NON_FICTION
  POETRY
  OTHER
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String    @db.Text
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  String?
  tags      String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  comments  Comment[]
  likes     Like[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  authorId  String
  postId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
}

enum MatchStatus {
  PENDING
  ACCEPTED
  DECLINED
  UNMATCHED
}

model Match {
  id          String      @id @default(uuid())
  requesterId String
  receiveeId  String
  status      MatchStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  requester   User        @relation("MatchesInitiated", fields: [requesterId], references: [id], onDelete: Cascade)
  receivee    User        @relation("MatchesReceived", fields: [receiveeId], references: [id], onDelete: Cascade)
  ideas       Idea[]

  @@unique([requesterId, receiveeId])
  @@index([requesterId, receiveeId])
}

enum NotificationType {
  MATCH_REQUEST
  MATCH_ACCEPTED
  FEEDBACK_RECEIVED
  IDEA_ADDED
  EVENT_STARTING
  DAILY_REMINDER
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String
  data        Json?
  referenceId String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id        String   @id @default(uuid())
  matchId   String
  authorId  String
  type      String   // CHARACTER, PLOT, WORLD, DIALOGUE, OTHER
  content   String   @db.Text
  tags      String[]
  isPinned  Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   IdeaReply[]
}

model IdeaReply {
  id        String   @id @default(uuid())
  ideaId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

enum PromptType {
  DAILY
  COMMUNITY
}

model Prompt {
  id              String             @id @default(uuid())
  content         String             @db.Text
  genre           Genre
  theme           String?
  type            PromptType         @default(COMMUNITY)
  isPublished     Boolean            @default(false)
  publishedAt     DateTime?
  authorId        String?            
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  author          User?              @relation(fields: [authorId], references: [id])
  upvotes         PromptUpvote[]
  submissions     PromptSubmission[]
}

model PromptUpvote {
  promptId        String
  userId          String
  createdAt       DateTime           @default(now())

  prompt          Prompt             @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([promptId, userId])
}

model PromptSubmission {
  id              String             @id @default(uuid())
  promptId        String
  authorId        String
  content         String             @db.Text
  wordCount       Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  prompt          Prompt             @relation(fields: [promptId], references: [id], onDelete: Cascade)
  author          User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments        SubmissionComment[]
}

model SubmissionComment {
  id              String             @id @default(uuid())
  submissionId    String
  authorId        String
  content         String             @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  submission      PromptSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author          User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

enum RequestStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

enum FocusArea {
  CLARITY
  PACING
  DIALOGUE
  STRUCTURE
  VOICE
  CHARACTER
}

model FeedbackRequest {
  id          String             @id @default(uuid())
  authorId    String
  title       String
  excerpt     String             @db.Text
  genre       Genre
  focusAreas  FocusArea[]
  context     String?            @db.Text
  status      RequestStatus      @default(OPEN)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  author      User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  responses   FeedbackResponse[]
}

model FeedbackResponse {
  id                String          @id @default(uuid())
  requestId         String
  reviewerId        String
  overallImpression String          @db.Text
  clarityScore      Int
  pacingScore       Int
  dialogueScore     Int
  structureScore    Int
  detailedNotes     String          @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  request           FeedbackRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reviewer          User            @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([requestId, reviewerId])
}

model WritingLog {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  wordCount   Int
  projectName String?  @default("Default")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, projectName])
  @@index([userId, date])
}

enum EventType {
  SPRINT
  CHALLENGE
  WORKSHOP
}

model Event {
  id              String             @id @default(uuid())
  title           String
  description     String             @db.Text
  type            EventType          @default(SPRINT)
  startTime       DateTime
  endTime         DateTime
  targetWords     Int?
  maxParticipants Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  participants    EventParticipant[]
}

model EventParticipant {
  id          String   @id @default(uuid())
  eventId     String
  userId      String
  wordCount   Int      @default(0)
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}
